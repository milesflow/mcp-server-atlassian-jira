# Copy to `.env` for local CLI runs (e.g. `npm run cli`, tests).
# MCP clients (Cursor, Claude) usually set the same variables in their server `env` block instead.

# Enable debug logging
DEBUG=false

# --- Recommended: multiple Jira Cloud sites (profiles JSON file) ---
# Prefer these when one MCP server should reach more than one site.
# Use an absolute path. `ATLASSIAN_DEFAULT_PROFILE` overrides `defaultProfile` inside the file.
# ATLASSIAN_DEFAULT_PROFILE=company
# ATLASSIAN_PROFILES_FILE=/absolute/path/to/jira-profiles.json
#
# File shape (see README):
# {"defaultProfile":"company","profiles":{"company":{"siteName":"your-company","userEmail":"you@example.com","apiToken":"..."}}}
#
# Note: `ATLASSIAN_PROFILES_JSON` is not supported; use `ATLASSIAN_PROFILES_FILE` instead.

# --- Legacy: single Jira site only ---
# Use when you do not set `ATLASSIAN_PROFILES_FILE`.
# Your Jira site name (for https://your-instance.atlassian.net)
ATLASSIAN_SITE_NAME=your-instance
# Your Atlassian account email
ATLASSIAN_USER_EMAIL=your-email@example.com
# Your Atlassian API token (https://id.atlassian.com/manage-profile/security/api-tokens)
ATLASSIAN_API_TOKEN=

# --- Tempo Cloud (optional — enables tempo_* MCP tools) ---
# Create token: Jira → Tempo → Settings → Data Access → API Integration
TEMPO_API_TOKEN=YOUR_TEMPO_API_TOKEN
# Base URL for Tempo REST API v4 (no trailing slash). Change only if Tempo docs specify a regional host.
TEMPO_API_BASE_URL=https://api.tempo.io/4
